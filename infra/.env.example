# Local / dev infrastructure connection defaults (docker-compose.infra.yml)

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=futbot
POSTGRES_PASSWORD=futbot
POSTGRES_DB=futbot

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=futbot
MINIO_SECRET_KEY=futbotminio
MINIO_BUCKET=futbot-uploads

QDRANT_URL=http://localhost:6333

# Phase 1 — Auth + Gateway
JWT_SECRET=dev-secret-change-me-change-in-production
DATABASE_URL=postgresql+asyncpg://futbot:futbot@localhost:5432/futbot
AUTH_SERVICE_URL=http://localhost:8081
CHAT_SERVICE_URL=http://localhost:8082
PROJECT_SERVICE_URL=http://localhost:8083
ANON_MESSAGE_LIMIT=10
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Phase 2 — Context budget
CONTEXT_BUDGET_TOKENS=8192
AUTO_COMPRESS_THRESHOLD_PCT=85
HOT_CONTEXT_WINDOW=10
LLM_GATEWAY_URL=http://localhost:8087
LLM_PROVIDER=local
GROQ_API_KEY=
GROQ_MAX_RETRIES=5
GROQ_BACKOFF_BASE=1.5
LLM_RATE_LIMIT_RPM=60
SNAPSHOT_MAX_TOKENS=300

# FutBot — environment template
# Copy to `.env` and fill in secrets:
#   cp .env.example .env
#
# Used by docker-compose.services.yml (env_file) and local `uvicorn` runs.
# Docker Compose overrides service URLs (e.g. http://postgres:5432) in
# docker-compose.services.yml — values here target localhost / bare-metal dev.

# =============================================================================
# Infrastructure (postgres, redis, minio, qdrant)
# =============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=futbot
POSTGRES_PASSWORD=futbot
POSTGRES_DB=futbot

DATABASE_URL=postgresql+asyncpg://futbot:futbot@localhost:5432/futbot

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=futbot
MINIO_SECRET_KEY=futbotminio
MINIO_BUCKET=futbot-projects
MINIO_SECURE=false

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=futbot_chunks
DATA_DIR=data

# =============================================================================
# Gateway (:8000)
# =============================================================================

AUTH_SERVICE_URL=http://localhost:8081
CHAT_SERVICE_URL=http://localhost:8082
PROJECT_SERVICE_URL=http://localhost:8083
INGESTION_SERVICE_URL=http://localhost:8086
ORCHESTRATOR_SERVICE_URL=http://localhost:8084
OBSERVABILITY_SERVICE_URL=http://localhost:8090
TOOLS_SERVICE_URL=http://localhost:8088
LLM_SERVICE_URL=http://localhost:8087
RETRIEVAL_SERVICE_URL=http://localhost:8085

JWT_SECRET=dev-secret-change-me-change-in-production
ANON_MESSAGE_LIMIT=10

# =============================================================================
# Auth (:8081) — secrets required for OAuth in production
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback

ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
SETUP_TOKEN_MINUTES=30
STEP_UP_TOKEN_MINUTES=5

# =============================================================================
# Chat (:8082)
# =============================================================================

CONTEXT_BUDGET_TOKENS=8192
AUTO_COMPRESS_THRESHOLD_PCT=85
HOT_CONTEXT_WINDOW=10
SNAPSHOT_MAX_TOKENS=300

LLM_GATEWAY_URL=http://localhost:8087

# =============================================================================
# LLM gateway (:8087)
# =============================================================================

# local = self-hosted models via URL_* below | groq = Groq API
LLM_PROVIDER=local

# Required when LLM_PROVIDER=groq
GROQ_API_KEY=

GROQ_MAX_RETRIES=5
GROQ_BACKOFF_BASE=1.5
GROQ_BACKOFF_MAX_SEC=60
LLM_RATE_LIMIT_RPM=60

# Groq model IDs (used when LLM_PROVIDER=groq)
GROQ_MODEL_120B=openai/gpt-oss-120b
GROQ_MODEL_32B=qwen/qwen3-32b
GROQ_MODEL_MAIN=qwen/qwen3.6-27b
GROQ_MODEL_ORCHESTRATOR=openai/gpt-oss-20b

# Local model endpoints (used when LLM_PROVIDER=local)
MODEL_ORCHESTRATOR=Qwen/Qwen3.5-0.8B
MODEL_GENERATOR=Qwen/Qwen3.5-2B
MODEL_DECISION=Qwen/Qwen3.5-4B
URL_08B=
URL_2B=
URL_4B=

# =============================================================================
# RAG orchestrator (:8084)
# =============================================================================

TRACE_DB_PATH=trace_logs.db

# =============================================================================
# Retrieval (:8085)
# =============================================================================

RETRIEVAL_DENSE_TOP_K=15
RETRIEVAL_SPARSE_TOP_K=15
RETRIEVAL_DEFAULT_TOP_K=5

# =============================================================================
# Ingestion (:8086)
# =============================================================================

INGEST_ASYNC_IMAGE_THRESHOLD=3
INGEST_IMAGE_DELAY_MS=500
INGEST_OCR_ENABLED=true
INGEST_OCR_MIN_CONFIDENCE=60
CHUNK_TARGET_TOKENS=400
CHUNK_OVERLAP_SENTENCES=2
TABLE_CHUNK_ROWS=10

# =============================================================================
# Tools (:8088) — API keys required for web search / football MCP
# =============================================================================

# Web search: at least one of Tavily or Serper recommended
TAVILY_API_KEY=
SERPER_API_KEY=
TOOLS_REQUEST_TIMEOUT_SEC=30

# Football MCP
LIVESCORE_MCP_URL=https://livescoremcp.com/sse
LIVESCORE_MCP_ENABLED=true
API_FOOTBALL_MCP_ENABLED=true
API_FOOTBALL_KEY=
API_FOOTBALL_MCP_COMMAND=node
API_FOOTBALL_MCP_ARGS=packages/api-football-mcp/dist/index.js

# PDF export (npx MCP packages)
PDF_MCP_PRIMARY=md-pdf-mcp
PDF_MCP_FALLBACK=md-to-pdf-mcp

# =============================================================================
# Project / storage (tests only)
# =============================================================================

# Set to "memory" to skip MinIO in project service tests
STORAGE_BACKEND=
